{
  "name": "b.0218.jp",
  "version": "3.1.0",
  "private": true,
  "scripts": {
    "prebuild": "bash scripts/prebuild.sh",
    "build": "TZ='Asia/Tokyo' next build --webpack",
    "build:analyzer": "ANALYZE=true next build --webpack",
    "build:article": "TZ='Asia/Tokyo' NODE_OPTIONS='--disable-warning=ExperimentalWarning' node --require esbuild-register ./build/article",
    "build:ogp": "node --require esbuild-register ./build/ogp/index.ts",
    "build:popular": "node --require esbuild-register ./build/popular",
    "build:search": "node --require esbuild-register ./build/search",
    "build:category": "node --require esbuild-register ./build/category",
    "build:similarity": "node --require esbuild-register ./build/similarity",
    "coverage": "vitest run --coverage",
    "dev": "NODE_OPTIONS='--inspect' next dev -p 8080 --experimental-https --webpack",
    "dev:ogp": "DEBUG=true node --require esbuild-register ./build/ogp/server.tsx",
    "knip": "knip",
    "knip:fix": "knip --fix --allow-remove-files",
    "knip:report": "knip --reporter json > knip-report.json",
    "lint": "biome check src build tools tests",
    "lint:css": "stylelint \"src/**/*.{css,ts,tsx}\"",
    "lint:markup": "markuplint \"src/**/*.{jsx,tsx}\"",
    "lint:write": "biome check --write --unsafe src build tools tests",
    "prepare": "husky && playwright install --only-shell && panda codegen",
    "start": "next start",
    "storybook": "panda codegen && storybook dev -p 6006",
    "build-storybook": "panda codegen && storybook build",
    "test:storybook": "vitest --run src/stories/storybook-interactions.test.tsx",
    "test": "vitest --run",
    "vrt": "playwright test --config playwright.vrt.config.ts",
    "vrt:build": "npm run build-storybook",
    "vrt:pull-baseline": "bash scripts/vrt-pull-baseline.sh",
    "vrt:ui": "playwright test --config playwright.vrt.config.ts --ui",
    "vrt:update": "playwright test --config playwright.vrt.config.ts --update-snapshots",
    "e2e": "playwright test --config playwright.e2e.config.ts",
    "e2e:ui": "playwright test --config playwright.e2e.config.ts --ui",
    "e2e:debug": "playwright test --config playwright.e2e.config.ts --debug"
  },
  "nano-staged": {
    "**/*.{ts,tsx,js,mjs}": [
      "biome check --write",
      "bash -c 'tsc --noEmit --skipLibCheck'"
    ],
    "**/*.{ts,tsx}": [
      "biome check --write",
      "stylelint --fix --cache"
    ],
    "**/*.css": [
      "prettier --write --cache --experimental-cli",
      "stylelint --fix --cache"
    ],
    "**/*.{yml,yaml}": [
      "prettier --write --cache --experimental-cli"
    ],
    "**/*.md": [
      "prettier --write --cache --experimental-cli"
    ]
  },
  "browserslist": [
    "chrome 143",
    "edge 142",
    "firefox 145",
    "safari 26.2"
  ],
  "prettier": {
    "plugins": [
      "@prettier/plugin-oxc"
    ],
    "printWidth": 120,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "overrides": {
    "next-scroll-restorer": {
      "next": "$next"
    },
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "dependencies": {
    "@adobe/spectrum-tokens": "14.13.2",
    "@heroicons/react": "2.2.0",
