# 必須: タイムゾーン
TZ=Asia/Tokyo

# Google Analytics を取得する場合は必須（SKIP_GA=true の場合は不要）
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_PROPERTY_ID=123456789
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 任意: ビルド時の Google Analytics 取得をスキップする
# SKIP_GA=true

# 任意: prebuild 時の OGP 画像生成をスキップする
# SKIP_OGP=true

# 任意: OGP 画像生成の並列数とワーカーごとの処理数
# OGP_WORKERS=4
# OGP_PAGES_PER_WORKER=8

# 任意: 既存 OGP 画像を無視して再生成する
# OGP_FORCE=true

# 任意: OGP 生成のデバッグ出力を有効にする
# DEBUG=true

# 任意: 未来日付の記事を出力に含める
# IS_DEVELOPMENT=true
